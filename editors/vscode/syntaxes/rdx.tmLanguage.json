        {
          "include": "#fenced_code_block_tsx"
        },
        {
          "include": "#fenced_code_block_jsx"
        },
        {
          "include": "#fenced_code_block_less"
        },
        {
          "include": "#fenced_code_block_scss"
        },
        {
          "include": "#fenced_code_block_makefile"
