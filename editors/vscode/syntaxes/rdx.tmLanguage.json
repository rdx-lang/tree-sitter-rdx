{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RDX",
  "scopeName": "source.rdx",
  "patterns": [
    {
      "include": "#frontmatter"
    },
    {
      "include": "#fenced-code-blocks"
    },
    {
      "include": "#display-math"
    },
    {
      "include": "#html-comment"
    },
    {
      "include": "#component-tag"
    },
    {
      "include": "#component-close-tag"
    },
    {
      "include": "#inline-code"
    },
    {
      "include": "#variable-interpolation"
    },
    {
      "include": "#inline-math"
    },
    {
      "include": "#escaped-sequence"
    },
    {
      "include": "#markdown-heading"
    },
    {
      "include": "#markdown-bold"
    },
    {
      "include": "#markdown-italic"
    },
    {
      "include": "#markdown-strikethrough"
    },
    {
      "include": "#markdown-link"
    },
    {
      "include": "#markdown-image"
    },
    {
      "include": "#markdown-blockquote"
    },
    {
      "include": "#markdown-horizontal-rule"
    },
    {
      "include": "#markdown-list"
    },
    {
      "include": "#markdown-footnote-ref"
    }
  ],
  "repository": {
    "frontmatter": {
      "name": "meta.embedded.block.yaml",
      "begin": "\\A---\\s*$",
      "end": "^---\\s*$",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.frontmatter.begin.rdx"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.frontmatter.end.rdx"
        }
      },
      "patterns": [
        {
          "include": "source.yaml"
        }
      ]
    },
    "component-tag": {
      "name": "meta.tag.rdx",
      "begin": "(<)([A-Z][a-zA-Z0-9_]*)",
      "end": "(/?>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.rdx"
        },
        "2": {
          "name": "entity.name.tag.rdx"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.rdx"
        }
      },
      "patterns": [
        {
          "include": "#attributes"
        }
      ]
    },
    "component-close-tag": {
      "match": "(</)([A-Z][a-zA-Z0-9_]*)(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.end.rdx"
        },
        "2": {
          "name": "entity.name.tag.rdx"
        },
        "3": {
          "name": "punctuation.definition.tag.end.rdx"
        }
      }
    },
    "attributes": {
      "patterns": [
        {
          "include": "#json-attribute"
        },
        {
          "include": "#variable-attribute"
        },
        {
          "include": "#primitive-attribute"
        },
        {
          "include": "#string-attribute-double"
        },
        {
          "include": "#string-attribute-single"
        },
        {
          "include": "#boolean-shorthand-attribute"
        }
      ]
    },
    "string-attribute-double": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(=)(\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\")",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        },
        "2": {
          "name": "punctuation.separator.key-value.rdx"
        },
        "3": {
          "name": "string.quoted.double.rdx"
        }
      }
    },
    "string-attribute-single": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(=)('[^'\\\\]*(?:\\\\.[^'\\\\]*)*')",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        },
        "2": {
          "name": "punctuation.separator.key-value.rdx"
        },
        "3": {
          "name": "string.quoted.single.rdx"
        }
      }
    },
    "primitive-attribute": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(=)(\\{)(true|false|null|-?[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?)(\\})",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        },
        "2": {
          "name": "punctuation.separator.key-value.rdx"
        },
        "3": {
          "name": "punctuation.definition.brace.begin.rdx"
        },
        "4": {
          "name": "constant.language.rdx"
        },
        "5": {
          "name": "punctuation.definition.brace.end.rdx"
        }
      }
    },
    "json-attribute": {
      "name": "meta.attribute.json.rdx",
      "begin": "([a-zA-Z_][a-zA-Z0-9_]*)(=\\{\\{)",
      "end": "(\\}\\})",
      "beginCaptures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        },
        "2": {
          "name": "punctuation.definition.brace.begin.rdx"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.brace.end.rdx"
        }
      },
      "patterns": [
        {
          "include": "source.json"
        }
      ]
    },
    "variable-attribute": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(=)(\\{)(\\$[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)(\\})",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        },
        "2": {
          "name": "punctuation.separator.key-value.rdx"
        },
        "3": {
          "name": "punctuation.definition.brace.begin.rdx"
        },
        "4": {
          "name": "support.variable.rdx"
        },
        "5": {
          "name": "punctuation.definition.brace.end.rdx"
        }
      }
    },
    "boolean-shorthand-attribute": {
      "match": "(?<=\\s)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s|/?>)",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.rdx"
        }
      }
    },
    "variable-interpolation": {
      "match": "(\\{)(\\$[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)(\\})",
      "captures": {
        "1": {
          "name": "punctuation.definition.interpolation.begin.rdx"
        },
        "2": {
          "name": "support.variable.rdx"
        },
        "3": {
          "name": "punctuation.definition.interpolation.end.rdx"
        }
      }
    },
    "escaped-sequence": {
      "match": "\\\\(\\{\\$|\\{\\{|\\}\\}|\\{|\\\\)",
      "name": "constant.character.escape.rdx"
    },
    "fenced-code-blocks": {
      "patterns": [
        {
          "include": "#fenced_code_block_js"
        },
        {
          "include": "#fenced_code_block_ts"
        },
        {
          "include": "#fenced_code_block_python"
        },
        {
          "include": "#fenced_code_block_rust"
        },
        {
          "include": "#fenced_code_block_go"
        },
        {
          "include": "#fenced_code_block_json"
        },
        {
          "include": "#fenced_code_block_yaml"
        },
        {
          "include": "#fenced_code_block_html"
        },
        {
          "include": "#fenced_code_block_css"
        },
        {
          "include": "#fenced_code_block_shell"
        },
        {
          "include": "#fenced_code_block_c"
        },
        {
          "include": "#fenced_code_block_cpp"
        },
        {
          "include": "#fenced_code_block_java"
        },
        {
          "include": "#fenced_code_block_sql"
        },
        {
          "include": "#fenced_code_block_ruby"
