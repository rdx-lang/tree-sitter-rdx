{
  "comments": {
    "blockComment": [
      "<!--",
      "-->"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "{{",
      "}}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "{{",
      "close": "}}"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "`",
      "close": "`",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "<!--",
      "close": " -->"
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "`",
      "`"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "**",
      "**"
    ],
    [
      "*",
      "*"
    ],
    [
      "~~",
      "~~"
    ]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<[A-Z][a-zA-Z0-9_]*",
      "end": "^\\s*</[A-Z][a-zA-Z0-9_]*>"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*<[A-Z][a-zA-Z0-9_]*(?:\\s[^/]*)?\\s*>\\s*$",
    "decreaseIndentPattern": "^\\s*</[A-Z][a-zA-Z0-9_]*>\\s*$"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\$\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*<[A-Z][a-zA-Z0-9_]*[^/]*>\\s*$",
      "afterText": "^\\s*</[A-Z][a-zA-Z0-9_]*>\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*<[A-Z][a-zA-Z0-9_]*[^/]*>\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}