{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rdx",
  "rules": {
    "document": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "frontmatter"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_body_content"
          }
        }
      ]
    },
    "frontmatter": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_frontmatter_open"
          },
          "named": true,
          "value": "frontmatter_delimiter"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_frontmatter_content"
          },
          "named": true,
          "value": "frontmatter_content"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_frontmatter_close"
          },
          "named": true,
          "value": "frontmatter_delimiter"
        }
      ]
    },
    "_body_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "component"
        },
        {
          "type": "SYMBOL",
          "name": "self_closing_component"
        },
        {
          "type": "SYMBOL",
          "name": "variable_interpolation"
        },
        {
          "type": "SYMBOL",
          "name": "escaped_sequence"
        },
        {
          "type": "SYMBOL",
          "name": "fenced_code_block"
        },
        {
          "type": "SYMBOL",
          "name": "display_math"
        },
        {
          "type": "SYMBOL",
          "name": "inline_math"
        },
        {
          "type": "SYMBOL",
          "name": "inline_code"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "escaped_sequence": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "\\{$"
          },
          {
            "type": "STRING",
            "value": "\\{{"
          },
          {
            "type": "STRING",
            "value": "\\}}"
          },
          {
            "type": "STRING",
            "value": "\\{"
          },
          {
            "type": "STRING",
            "value": "\\\\"
          }
        ]
      }
    },
    "fenced_code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_code_fence_open"
          },
          "named": true,
          "value": "code_fence_delimiter"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code_language"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_code_content"
              },
              "named": true,
              "value": "code_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_code_fence_close"
          },
          "named": true,
          "value": "code_fence_delimiter"
        }
      ]
    },
    "code_language": {
      "type": "PATTERN",
      "value": "[^\\n`]+"
    },
    "inline_code": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "PATTERN",
          "value": "[^`]+"
        },
        {
          "type": "STRING",
          "value": "`"
        }
      ]
    },
    "display_math": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_math_fence_open"
          },
          "named": true,
          "value": "math_delimiter"
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_math_content"
              },
              "named": true,
              "value": "math_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_math_fence_close"
          },
          "named": true,
          "value": "math_delimiter"
        }
      ]
    },
    "inline_math": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "$"
          },
          {
            "type": "SYMBOL",
            "name": "math_expression"
          },
          {
            "type": "STRING",
            "value": "$"
          }
        ]
      }
    },
    "math_expression": {
      "type": "PATTERN",
      "value": "[^\\s$][^$]*"
    },
    "component": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "open_tag"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_component_child"
          }
        },
        {
          "type": "SYMBOL",
          "name": "close_tag"
        }
      ]
    },
    "_component_child": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "component"
        },
        {
          "type": "SYMBOL",
          "name": "self_closing_component"
        },
        {
          "type": "SYMBOL",
          "name": "variable_interpolation"
        },
        {
          "type": "SYMBOL",
          "name": "escaped_sequence"
        },
        {
          "type": "SYMBOL",
          "name": "inline_math"
        },
        {
          "type": "SYMBOL",
          "name": "inline_code"
        },
        {
          "type": "SYMBOL",
          "name": "component_text"
        }
      ]
    },
    "component_text": {
      "type": "PATTERN",
      "value": "[^<{`\\\\]+"
    },
    "open_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "tag_name"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "attribute"
          }
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "close_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "</"
        },
        {
          "type": "SYMBOL",
          "name": "tag_name"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "self_closing_component": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "tag_name"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "attribute"
          }
        },
        {
          "type": "STRING",
          "value": "/>"
        }
      ]
    },
    "tag_name": {
      "type": "PATTERN",
      "value": "[A-Z][a-zA-Z0-9_]*"
    },
    "attribute": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "primitive_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "json_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "variable_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "boolean_shorthand_attribute"
        }
      ]
    },
    "boolean_shorthand_attribute": {
      "type": "SYMBOL",
      "name": "attribute_name"
    },
    "string_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "="
          }
        },
        {
          "type": "SYMBOL",
          "name": "string_value"
        }
      ]
    },
    "primitive_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "="
          }
        },
        {
          "type": "SYMBOL",
          "name": "primitive_value"
        }
      ]
    },
    "json_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "={{"
          }
        },
        {
          "type": "SYMBOL",
          "name": "json_content"
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "variable_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "="
          }
        },
        {
          "type": "SYMBOL",
          "name": "variable_value"
        }
      ]
    },
    "attribute_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_-]*"
    },
    "string_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "double_quoted_content"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "single_quoted_content"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "double_quoted_content": {
      "type": "PATTERN",
      "value": "([^\"\\\\]|\\\\.)+"
    },
    "single_quoted_content": {
      "type": "PATTERN",
      "value": "([^'\\\\]|\\\\.)+"
    },
    "primitive_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_primitive_literal"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_primitive_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number_literal"
        },
        {
          "type": "SYMBOL",
          "name": "boolean_literal"
        },
        {
          "type": "SYMBOL",
          "name": "null_literal"
        }
      ]
    },
    "number_literal": {
      "type": "PATTERN",
      "value": "-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?"
    },
    "boolean_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "null_literal": {
      "type": "STRING",
      "value": "null"
    },
    "json_content": {
      "type": "REPEAT1",
      "content": {
        "type": "PATTERN",
        "value": "[^}]+|\\}[^}]"
      }
    },
    "variable_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "variable_path"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "variable_interpolation": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "variable_path"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "variable_path": {
      "type": "PATTERN",
      "value": "\\$[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
    },
    "text": {
      "type": "PATTERN",
      "value": "[^<{`\\\\$]+|<[^A-Z/\\s]|[{\\\\]"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_code_fence_open"
    },
    {
      "type": "SYMBOL",
      "name": "_code_content"
    },
    {
      "type": "SYMBOL",
      "name": "_code_fence_close"
    },
    {
      "type": "SYMBOL",
      "name": "_math_fence_open"
    },
    {
      "type": "SYMBOL",
      "name": "_math_content"
    },
    {
      "type": "SYMBOL",
      "name": "_math_fence_close"
    },
    {
      "type": "SYMBOL",
      "name": "_frontmatter_open"
    },
    {
      "type": "SYMBOL",
      "name": "_frontmatter_content"
    },
    {
      "type": "SYMBOL",
      "name": "_frontmatter_close"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}